---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Project | AI Coach">
    <div class="page-wrapper" style="padding: 0; display: flex; flex-direction: column; height: 100vh;">
        <!-- Header -->
        <header style="display: flex; align-items: center; gap: 12px; padding: 16px; border-bottom: 1px solid var(--border-subtle); background: var(--bg-darker);">
            <a href="/" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; background: var(--bg-glass); color: var(--text-secondary); transition: all 0.15s ease;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
            </a>
            <div style="flex: 1; min-width: 0;">
                <h1 id="project-title" style="font-size: 1rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Project</h1>
                <p style="font-size: 0.75rem; color: var(--text-muted);">Chat with your coach</p>
            </div>
            <button id="btn-checkin" class="btn btn-primary" style="padding: 8px 16px; font-size: 0.75rem;">
                Check-in
            </button>
        </header>

        <!-- Content -->
        <div style="flex: 1; overflow-y: auto; padding: 20px;">
            <div style="max-width: 600px; margin: 0 auto;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                    <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600;">
                        Action Plan
                    </h2>
                    <button id="btn-delete" class="btn btn-secondary" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.2); padding: 6px 12px; font-size: 0.75rem;">
                        Delete Project
                    </button>
                </div>
                
                <div id="task-list"></div>
                
                <div class="empty-state" id="empty-state" style="padding: 32px 24px; display: none;">
                    <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 11l3 3L22 4"></path>
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                    </svg>
                    <p class="empty-state-title">No tasks yet</p>
                    <p style="font-size: 0.875rem;">Ask the AI Coach to create a plan for you.</p>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Smooth back button hover */
    a:hover {
        background: var(--bg-card-hover) !important;
        color: var(--text-primary) !important;
    }
</style>

<script>
    import { storage } from '../../store/storage.js';
    
    // UI Refs
    const ui = {
        title: document.getElementById('project-title'),
        btnCheckin: document.getElementById('btn-checkin'),
        btnDelete: document.getElementById('btn-delete'),
        taskList: document.getElementById('task-list'),
        emptyState: document.getElementById('empty-state')
    };

    const projectId = window.location.pathname.split('/project/')[1];
    let project = storage.getProject(projectId);

    if (!project) {
        window.location.href = '/';
    } else {
        ui.title.textContent = project.title;
        renderTasks(); 
    }

    // Event Listeners
    ui.btnCheckin.addEventListener('click', () => {
        window.location.href = '/chat';
    });

    ui.btnDelete.addEventListener('click', () => {
        if (confirm('Are you sure you want to delete this project? This cannot be undone.')) {
            storage.deleteProject(projectId);
            window.location.href = '/';
        }
    });

    // Keep track of which groups are collapsed
    const collapsedGroups = new Set();

    // --- Task Rendering ---
    function renderTasks() {
        // Refresh project data
        project = storage.getProject(projectId);
        if (!project) return;

        const tasks = project.tasks || [];
        ui.taskList.innerHTML = '';

        if (tasks.length === 0) {
            ui.emptyState.style.display = 'block';
            return;
        }
        ui.emptyState.style.display = 'none';

        tasks.forEach((task, taskIndex) => {
            const hasSubtasks = task.subtasks && task.subtasks.length > 0;
            // A group is fully completed if all its subtasks are completed (or if it has no subtasks, check its own completed flag)
            const isFullyCompleted = hasSubtasks 
                ? task.subtasks.every(s => s.completed) 
                : !!task.completed;

            const groupEl = document.createElement('div');
            groupEl.className = `task-group-card ${isFullyCompleted ? 'completed' : ''}`;
            
            const isCollapsed = collapsedGroups.has(taskIndex);

            // Note: We remove priority pills as per requirements for a calmer UI
            groupEl.innerHTML = `
                <div class="task-group-card-header" data-toggle="${taskIndex}">
                    <div class="task-group-title ${isFullyCompleted ? 'completed' : ''}">${escapeHtml(task.title)}</div>
                    <svg class="task-group-chevron ${isCollapsed ? '' : 'expanded'}" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </div>
            `;
            
            // Render subtasks if any
            if (hasSubtasks) {
                const childrenContainer = document.createElement('div');
                childrenContainer.className = 'task-group-children';
                if (isCollapsed) childrenContainer.style.display = 'none';

                task.subtasks.forEach((sub, subIndex) => {
                    const childEl = document.createElement('div');
                    childEl.className = 'task-child-item';
                    
                    // Recurring indicator check (mock logic: if title contains "every" or "daily")
                    // Note: Just styling it if it exists. AI might assign a recurring flag or we infer it.
                    const isRecurring = sub.recurring || (sub.title && sub.title.toLowerCase().includes('daily'));
                    const recurringHtml = isRecurring ? '<span class="recurring-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>Recurring</span>' : '';

                    childEl.innerHTML = `
                        <div class="task-checkbox ${sub.completed ? 'completed' : ''}" data-task="${taskIndex}" data-sub="${subIndex}">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="${sub.completed ? '' : 'display: none;'}">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div style="flex: 1;">
                            <div class="task-child-title ${sub.completed ? 'completed' : ''}">${escapeHtml(sub.title)}</div>
                            ${sub.due_date ? `<div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">${sub.due_date} ${recurringHtml}</div>` : (recurringHtml ? `<div style="font-top: 2px;">${recurringHtml}</div>` : '')}
                        </div>
                    `;
                    childrenContainer.appendChild(childEl);
                });
                
                groupEl.appendChild(childrenContainer);
            } else {
                // If the group itself acts as a single task, allow marking it complete via a checkbox in the header
                // However, the new design specifies "parent groups are expandable... child tasks are actionable".
                // If there are no children, we make the parent itself the actionable item but designed as a child for consistency,
                // or just let it be a group with no children. Let's add a fake child line for the task itself if there are no subtasks.
                const childrenContainer = document.createElement('div');
                childrenContainer.className = 'task-group-children';
                if (isCollapsed) childrenContainer.style.display = 'none';
                
                const childEl = document.createElement('div');
                childEl.className = 'task-child-item';
                
                const isRecurring = task.recurring || (task.title && task.title.toLowerCase().includes('daily'));
                const recurringHtml = isRecurring ? '<span class="recurring-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>Recurring</span>' : '';

                childEl.innerHTML = `
                    <div class="task-checkbox ${task.completed ? 'completed' : ''}" data-index="${taskIndex}">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="${task.completed ? '' : 'display: none;'}">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </div>
                    <div style="flex: 1;">
                        <div class="task-child-title ${task.completed ? 'completed' : ''}">${escapeHtml(task.title)}</div>
                        ${task.due_date ? `<div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">${task.due_date} ${recurringHtml}</div>` : (recurringHtml ? `<div style="margin-top: 2px;">${recurringHtml}</div>` : '')}
                    </div>
                `;
                childrenContainer.appendChild(childEl);
                groupEl.appendChild(childrenContainer);
            }

            ui.taskList.appendChild(groupEl);
        });

        // Add click handlers for toggling expand/collapse
        document.querySelectorAll('.task-group-card-header[data-toggle]').forEach(header => {
            header.addEventListener('click', (e) => {
                const idx = parseInt(header.getAttribute('data-toggle'));
                if (collapsedGroups.has(idx)) collapsedGroups.delete(idx);
                else collapsedGroups.add(idx);
                renderTasks();
            });
        });

        // Add click handlers for checkboxes
        document.querySelectorAll('.task-checkbox[data-index]').forEach(cb => {
            cb.addEventListener('click', (e) => {
                e.stopPropagation();
                const idx = parseInt(cb.getAttribute('data-index'));
                toggleTask(idx);
            });
        });

        document.querySelectorAll('.task-checkbox[data-sub]').forEach(cb => {
            cb.addEventListener('click', (e) => {
                e.stopPropagation();
                const tIdx = parseInt(cb.getAttribute('data-task'));
                const sIdx = parseInt(cb.getAttribute('data-sub'));
                toggleSubtask(tIdx, sIdx);
            });
        });
    }

    function toggleTask(idx) {
        project.tasks[idx].completed = !project.tasks[idx].completed;
        storage.updateProjectTasks(project.id, project.tasks);
        renderTasks();
    }

    function toggleSubtask(tIdx, sIdx) {
        project.tasks[tIdx].subtasks[sIdx].completed = !project.tasks[tIdx].subtasks[sIdx].completed;
        storage.updateProjectTasks(project.id, project.tasks);
        renderTasks();
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>
