---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Settings | AI Accountability Coach">
	<div class="page-wrapper container" style="padding: 0; display: flex; flex-direction: column; min-height: 100vh; position: relative; background: var(--bg-dark); border-left: 1px solid var(--border-subtle); border-right: 1px solid var(--border-subtle);">
		<!-- Header -->
		<header style="display: flex; align-items: center; gap: 12px; padding: 16px; border-bottom: 1px solid var(--border-subtle); background: var(--bg-darker);">
			<a href="/" style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; background: var(--bg-glass); color: var(--text-secondary); transition: all 0.15s ease;" id="back-btn">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="15 18 9 12 15 6"></polyline>
				</svg>
			</a>
			<div style="flex: 1; text-align: center;">
				<h1 style="font-size: 1rem; font-weight: 600;">Settings</h1>
			</div>
			<!-- Spacer to balance the back button -->
			<div style="width: 40px;"></div>
		</header>

		<!-- Settings Content -->
		<div style="flex: 1; padding: 24px 16px;">
			<div style="width: 100%; margin: 0 auto;">
				
				<!-- Appearance Section -->
				<section class="animate-fade-in">
					<h2 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; margin-bottom: 16px;">
						Appearance
					</h2>
					
					<!-- Theme Toggle -->
					<div class="settings-card">
						<div style="display: flex; align-items: center; justify-content: space-between;">
							<div>
								<h3 style="font-size: 1rem; font-weight: 500; margin-bottom: 4px;">Theme</h3>
								<p style="font-size: 0.875rem; color: var(--text-muted);">
									Choose light or dark mode
								</p>
							</div>
							
							<!-- Toggle Switch -->
							<div class="theme-toggle" id="theme-toggle">
								<button class="theme-option" data-theme="light" title="Light mode">
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="5"></circle>
										<line x1="12" y1="1" x2="12" y2="3"></line>
										<line x1="12" y1="21" x2="12" y2="23"></line>
										<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
										<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
										<line x1="1" y1="12" x2="3" y2="12"></line>
										<line x1="21" y1="12" x2="23" y2="12"></line>
										<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
										<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
									</svg>
								</button>
								<button class="theme-option" data-theme="dark" title="Dark mode">
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
									</svg>
								</button>
							</div>
						</div>
					</div>
				</section>

				<!-- About Section -->
				<section class="animate-fade-in" style="margin-top: 32px; animation-delay: 100ms;">
					<h2 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; margin-bottom: 16px;">
						About
					</h2>
					
					<div class="settings-card">
						<div style="text-align: center; padding: 8px 0;">
							<h3 style="font-size: 1.125rem; font-weight: 600; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
								AI Accountability Coach
							</h3>
							<p style="font-size: 0.875rem; color: var(--text-muted); margin-top: 4px;">
								Version 1.0.0
							</p>
						</div>
					</div>
				</section>

				<!-- Danger Zone -->
				<section class="animate-fade-in" style="margin-top: 32px; animation-delay: 200ms;">
					<h2 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600; margin-bottom: 16px;">
						Data
					</h2>
					
					<div class="settings-card" style="border-color: rgba(239, 68, 68, 0.2);">
						<div style="display: flex; align-items: center; justify-content: space-between;">
							<div>
								<h3 style="font-size: 1rem; font-weight: 500; margin-bottom: 4px;">Reset All Data</h3>
								<p style="font-size: 0.875rem; color: var(--text-muted);">
									Delete all projects and settings
								</p>
							</div>
							<button id="btn-reset" class="btn" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 8px 16px; font-size: 0.875rem;">
								Reset
							</button>
						</div>
					</div>
				</section>

			</div>
		</div>
	</div>
</Layout>

<style>
	.settings-card {
		background: var(--bg-card);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-lg);
		padding: 20px;
		transition: all 0.15s ease;
	}

	.theme-toggle {
		display: flex;
		background: var(--bg-glass);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-md);
		padding: 4px;
		gap: 4px;
	}

	.theme-option {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 36px;
		border: none;
		border-radius: var(--radius-sm);
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.15s ease;
	}

	.theme-option:hover {
		color: var(--text-secondary);
	}

	.theme-option.active {
		background: var(--accent-gradient);
		color: white;
		box-shadow: 0 2px 8px -2px var(--accent-glow);
	}

	#btn-reset:hover {
		background: rgba(239, 68, 68, 0.2) !important;
	}

	#back-btn:hover {
		background: var(--bg-card-hover) !important;
		color: var(--text-primary) !important;
	}
</style>

<script>
	import { storage } from '../store/storage.js';

	// Get current theme
	const currentTheme = storage.getTheme();
	
	// UI Elements
	const themeToggle = document.getElementById('theme-toggle');
	const themeOptions = themeToggle.querySelectorAll('.theme-option');
	const btnReset = document.getElementById('btn-reset');

	// Set active state on current theme button
	themeOptions.forEach(btn => {
		if (btn.getAttribute('data-theme') === currentTheme) {
			btn.classList.add('active');
		}

		btn.addEventListener('click', () => {
			const theme = btn.getAttribute('data-theme');
			
			// Update active state
			themeOptions.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			
			// Apply theme
			storage.setTheme(theme);
		});
	});

	// Reset button
	btnReset.addEventListener('click', async () => {
		if (confirm('Are you sure you want to delete all your data? This cannot be undone.')) {
			await storage.clearAll();
		}
	});
</script>
